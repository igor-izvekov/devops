<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="20240102-1" author="developer">
        <comment>Insert default tags</comment>
        <insert tableName="tags">
            <column name="name" value="fiction"/>
            <column name="created_at" valueDate="now()"/>
        </insert>
        <insert tableName="tags">
            <column name="name" value="non-fiction"/>
            <column name="created_at" valueDate="now()"/>
        </insert>
        <insert tableName="tags">
            <column name="name" value="science"/>
            <column name="created_at" valueDate="now()"/>
        </insert>
        <insert tableName="tags">
            <column name="name" value="history"/>
            <column name="created_at" valueDate="now()"/>
        </insert>
        <insert tableName="tags">
            <column name="name" value="biography"/>
            <column name="created_at" valueDate="now()"/>
        </insert>
        
        <rollback>
            <delete tableName="tags">
                <where>name IN ('fiction', 'non-fiction', 'science', 'history', 'biography')</where>
            </delete>
        </rollback>
    </changeSet>
</databaseChangeLog>
